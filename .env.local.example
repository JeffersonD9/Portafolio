# ============================================================
# Gmail SMTP credentials
# ============================================================
# The Gmail account used to send emails FROM.
GMAIL_USER=you@gmail.com

# App Password — NOT your Gmail login password.
# Generate one at: myaccount.google.com > Security > 2-Step Verification > App Passwords
# Select "Mail" and the device, copy the 16-character code.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
# Recipient
# ============================================================
# The email address that receives contact form submissions.
# Defaults to GMAIL_USER if left empty.
CONTACT_RECIPIENT=you@gmail.com
